# ============================================
# StemFlow Environment Variables (MongoDB-Only)
# Copy this to .env and fill in your values
# ============================================

# --- MongoDB Atlas ---
# Full connection string from Atlas → Connect → Drivers → Node.js
# Include the database name (/stemflow) in the path
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/stemflow?retryWrites=true&w=majority

# --- JWT Secret ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_change_me

# --- Google Colab Backend (Ngrok URL — changes each session) ---
VITE_COLAB_API_URL=https://xxxx-xx-xx-xx-xx.ngrok-free.app
